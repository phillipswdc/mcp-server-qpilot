# QPilot API base URL. No trailing slash.
QPILOT_BASE_URL=https://api.qpilot.cloud

# Numeric site identifier this server scopes its calls and audit log to.
QPILOT_SITE_ID=

# Pre-encoded credential used as the value of `Authorization: Basic <token>`.
# Do NOT prefix with "Basic ". Treat as a secret.
QPILOT_AUTH_TOKEN=
